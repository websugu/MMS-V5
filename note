          rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Products - public read, admin write only
    match /products/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users - read for login/profile, write own profile only
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User subcollections (cart, orders, etc.)
    // Owner has full read/write. Admin can read for dashboard fallback.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Orders collection
    // Anyone authenticated can create an order.
    // Admins can read ALL orders (list queries allowed because no resource.data here).
    // Users can read their own orders (must use a filtered query matching resource.data.uid).
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && isAdmin();
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // Admin whitelist collection - only admins can read/write, public cannot access
    match /admins/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Helper function - checks hardcoded admin UID OR admins collection
    // Create a document at /admins/{uid} to grant admin access without redeploying rules
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'Dyj3kR9tvwYZJOovfuS1HjpgZdI2' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

  }
}




